# =====================================================================
#  Root .gitignore — Online Learning Management System (DBI202)
#  Mục tiêu: loại file bí mật / cục bộ / sinh tự động; GIỮ mã nguồn,
#  tài liệu, sơ đồ, ảnh screenshot, requirements.txt, .env.example.
# =====================================================================

# ---------- Secrets / biến môi trường ----------
# GIỮ file mẫu .env.example (không chứa bí mật); chặn .env thật.
# Lưu ý: .gitignore KHÔNG hỗ trợ comment cùng dòng -> để riêng dòng.
.env
.env.*
!.env.example

# ---------- Python: cache & bytecode ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------- Môi trường ảo Python ----------
.venv/
venv/
env/
ENV/

# ---------- Flask ----------
instance/
.webassets-cache

# ---------- Log ----------
*.log
logs/

# ---------- File tạm / backup ----------
*.tmp
*.temp
*.bak
*.old
*~
*.swp
*.swo

# ---------- File nén / lưu trữ ----------
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz

# ---------- IDE / editor cache ----------
.vs/
.vscode/
.idea/
*.suo
*.user

# ---------- Rác hệ điều hành ----------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ---------- File nộp bài: GIỮ TRÊN MÁY, KHÔNG push GitHub ----------
# Chỉ push mã nguồn để project chạy được; bản .docx/.pdf/.xlsx để nộp cục bộ.
*.docx
*.pdf
*.xls
*.xlsx
# File khóa tạm của MS Office (vd ~$AI_AuditLog...xlsx)
~$*

# ---------- Tài liệu nguồn gom lại: GIỮ TRÊN MÁY, KHÔNG push GitHub ----------
# Toàn bộ .md/sơ đồ/screenshots/script build phục vụ tạo báo cáo, không cần để chạy.
_tailieu_nguon/
