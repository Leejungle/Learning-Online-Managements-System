    classDef trig    fill:#FCE7F3,stroke:#db2777,stroke-width:1px,color:#831843;
    classDef store   fill:#E0E7FF,stroke:#4f46e5,stroke-width:2px,color:#312e81;

    class S,I,A,SYS actor;
