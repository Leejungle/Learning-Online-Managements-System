# ---------------------------------------------------------------------
# MẪU cấu hình web app. Copy file này thành `.env` rồi chỉnh nếu cần:
#     copy .env.example .env        (Windows)
# KHÔNG commit file `.env` thật (đã được .gitignore loại trừ).
# ---------------------------------------------------------------------

# --- Kết nối SQL Server (Windows Authentication) ---
# Web app kết nối bằng Windows Authentication (Trusted_Connection=yes),
# nên KHÔNG có username/password nào ở đây. Không cần bí mật.
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=localhost
DB_NAME=LMS
DB_TRUSTED_CONNECTION=yes
DB_TRUST_SERVER_CERTIFICATE=yes

# --- Cấu hình Flask ---
# Đặt FLASK_DEBUG=0 khi demo/thuyết trình cho ổn định.
FLASK_DEBUG=1
# Đổi sang một chuỗi ngẫu nhiên của riêng bạn cho phiên làm việc.
SECRET_KEY=change-me-to-a-random-string
